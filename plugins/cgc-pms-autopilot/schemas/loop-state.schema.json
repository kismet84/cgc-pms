{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/loop-state.schema.json",
  "title": "CGC PMS AutoPilot State v2",
  "description": "Durable single-writer state for the local unattended orchestrator.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "status",
    "phase",
    "currentIssue",
    "attempt",
    "startedAt",
    "phaseStartedAt",
    "lastHeartbeatAt",
    "iterationLimit",
    "completedImplementationIssues",
    "completedIssueIds",
    "worktree",
    "branch",
    "executorPid",
    "lastCommit",
    "failureFingerprint"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "DISABLED", "IDLE", "CHECKPOINT", "REFILLING", "SELECTING", "PLANNING",
        "EXECUTING", "VERIFYING", "REVIEWING", "REPAIRING", "CLOSING", "COMMITTING",
        "MERGING", "PAUSED", "BLOCKED", "LIMIT_REACHED", "STOPPED", "FAILED"
      ]
    },
    "phase": { "type": "string", "minLength": 1 },
    "currentIssue": { "type": "string" },
    "attempt": { "type": "integer", "minimum": 0 },
    "startedAt": { "type": "string", "format": "date-time" },
    "phaseStartedAt": { "type": "string", "format": "date-time" },
    "lastHeartbeatAt": { "type": "string", "format": "date-time" },
    "iterationLimit": { "type": ["integer", "null"], "minimum": 1, "maximum": 50 },
    "completedImplementationIssues": { "type": "integer", "minimum": 0 },
    "completedIssueIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "worktree": { "type": "string" },
    "branch": { "type": "string" },
    "executorPid": { "type": ["integer", "null"], "minimum": 1 },
    "executorStartedAt": { "type": ["string", "null"], "format": "date-time" },
    "lastProgressAt": { "type": ["string", "null"], "format": "date-time" },
    "retryCount": { "type": "integer", "minimum": 0, "maximum": 1 },
    "timeoutReason": { "type": ["string", "null"] },
    "retiredAt": { "type": ["string", "null"], "format": "date-time" },
    "retiredStatus": { "type": ["string", "null"], "enum": [null, "RETIRED"] },
    "retiredExecutors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issueId", "task", "executorPid", "startedAt", "lastProgressAt", "retryCount", "timeoutReason", "retiredAt", "retiredStatus"],
        "properties": {
          "issueId": { "type": "string" }, "task": { "type": "string" },
          "executorPid": { "type": "integer", "minimum": 1 },
          "startedAt": { "type": "string", "format": "date-time" },
          "lastProgressAt": { "type": "string", "format": "date-time" },
          "retryCount": { "type": "integer", "minimum": 0, "maximum": 1 },
          "timeoutReason": { "type": "string" },
          "retiredAt": { "type": "string", "format": "date-time" },
          "retiredStatus": { "const": "RETIRED" }
        }
      }
    },
    "lastCommit": { "type": ["string", "null"] },
    "failureFingerprint": { "type": ["string", "null"] },
    "enabled": { "type": "boolean" },
    "mode": { "type": "string" },
    "iterationCompleted": { "type": "integer", "minimum": 0 },
    "remainingIterations": { "type": ["integer", "null"], "minimum": 0 },
    "iterationLastCountedIssue": { "type": "string" },
    "lastAction": { "type": "string" },
    "lastIssue": { "type": "string" },
    "lastReason": { "type": "string" },
    "stopReason": { "type": "string" },
    "stopRequested": { "type": "boolean" },
    "autoMerge": { "type": "boolean" },
    "autoPush": { "const": false },
    "allowTestDataReset": { "type": "boolean" }
  }
}
