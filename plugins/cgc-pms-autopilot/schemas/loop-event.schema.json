{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/loop-event.schema.json",
  "title": "CGC PMS AutoPilot Durable Event",
  "type": "object",
  "additionalProperties": true,
  "required": ["runId", "issueId", "from", "to", "timestamp", "reason", "evidencePath"],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "issueId": { "type": "string" },
    "from": { "type": "string" },
    "to": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "reason": { "type": "string" },
    "evidencePath": { "type": "string" }
  }
}
