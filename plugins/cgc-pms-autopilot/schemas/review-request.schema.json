{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/review-request.schema.json",
  "title": "CGC PMS AutoPilot Review Request v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "issueId", "readyPath", "contextBasePath", "contextBaseHash", "contextDeltaPath", "contextDeltaHash", "diffPath", "diffSha256", "evidencePaths", "instructions"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "issueId": { "type": "string", "pattern": "^ISSUE-[0-9-]+$" },
    "readyPath": { "type": "string", "minLength": 1 },
    "contextBasePath": { "type": "string", "minLength": 1 },
    "contextBaseHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "contextDeltaPath": { "type": "string", "minLength": 1 },
    "contextDeltaHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "diffPath": { "type": "string", "minLength": 1 },
    "diffSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "evidencePaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "instructions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
