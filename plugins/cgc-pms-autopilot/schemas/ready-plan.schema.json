{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/ready-plan.schema.json",
  "title": "CGC PMS AutoPilot Ready Planner Result v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "candidateDecisions", "readyBlocks"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "candidateDecisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidateRef", "outcome", "reason", "readyIssueId", "failureCategory"],
        "properties": {
          "candidateRef": { "type": "string", "minLength": 1 },
          "outcome": { "enum": ["CREATED", "REJECTED", "BLOCKED"] },
          "reason": { "type": "string", "minLength": 1 },
          "readyIssueId": { "type": ["string", "null"], "pattern": "^ISSUE-[0-9-]+$" },
          "failureCategory": {
            "type": ["string", "null"],
            "enum": ["ready_issue_config", "tool_config", "environment_prereq", "quality_security", "needs_confirmation", null]
          }
        }
      }
    },
    "readyBlocks": {
      "type": "array",
      "maxItems": 5,
      "items": { "type": "string", "minLength": 100 }
    }
  }
}
