{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/evidence.schema.json",
  "title": "CGC PMS AutoPilot Verification Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "issueId", "baseCommit", "commit", "diffHash", "command", "startedAt", "durationSeconds", "exitCode", "classification", "summary", "rawLogPath"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "issueId": { "type": "string", "pattern": "^ISSUE-[0-9-]+$" },
    "baseCommit": { "type": "string", "minLength": 7 },
    "commit": { "type": "string", "minLength": 7 },
    "diffHash": { "type": "string", "minLength": 64, "maxLength": 64 },
    "command": { "type": "string", "minLength": 1 },
    "startedAt": { "type": "string", "format": "date-time" },
    "durationSeconds": { "type": "number", "minimum": 0 },
    "exitCode": { "type": "integer" },
    "classification": { "enum": ["pass", "fail", "timeout"] },
    "summary": { "type": "string" },
    "rawLogPath": { "type": "string", "minLength": 1 }
  }
}
