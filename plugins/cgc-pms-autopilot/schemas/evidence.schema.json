{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/evidence.schema.json",
  "title": "CGC PMS AutoPilot Verification Evidence v1/v2",
  "oneOf": [
    { "$ref": "#/$defs/v1" },
    { "$ref": "#/$defs/v2" }
  ],
  "$defs": {
    "common": {
      "type": "object",
      "required": ["issueId", "baseCommit", "commit", "diffHash", "command", "startedAt", "durationSeconds", "exitCode", "classification", "summary", "rawLogPath"],
      "properties": {
        "issueId": { "type": "string", "pattern": "^ISSUE-[0-9-]+$" },
        "baseCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "diffHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "command": { "type": "string", "minLength": 1 },
        "startedAt": { "type": "string", "format": "date-time" },
        "durationSeconds": { "type": "number", "minimum": 0 },
        "exitCode": { "type": "integer" },
        "classification": { "enum": ["pass", "fail", "timeout"] },
        "summary": { "type": "string" },
        "rawLogPath": { "type": "string", "minLength": 1 },
        "readyContentHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "v1": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["schemaVersion"],
          "properties": { "schemaVersion": { "const": 1 } }
        }
      ]
    },
    "v2": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": [
            "schemaVersion", "evidenceId", "sourceEvidenceId", "executionMode", "evidenceCategory",
            "executionBaseCommit", "readyContentHash", "contextBaseId", "contextBaseHash", "contextDeltaId",
            "contextDeltaHash", "candidateEvidenceHead", "controlPlanePolicyHash", "acceptanceRef", "commandHash",
            "environment", "environmentFingerprint"
          ],
          "properties": {
            "schemaVersion": { "const": 2 },
            "evidenceId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "sourceEvidenceId": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
            "executionMode": { "enum": ["EXECUTED", "REUSED"] },
            "evidenceCategory": { "enum": ["STATIC_CHEAP", "UNIT_BUILD", "INTEGRATION", "BROWSER"] },
            "executionBaseCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "contextBaseId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "contextBaseHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "contextDeltaId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "contextDeltaHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "candidateEvidenceHead": { "type": "string", "pattern": "^(?:[a-f0-9]{40})?$" },
            "controlPlanePolicyHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "acceptanceRef": { "type": "string", "minLength": 1 },
            "commandHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "environment": {
              "type": "object",
              "additionalProperties": false,
              "required": ["os", "osVersion", "architecture", "powershellVersion", "worktreeVolume"],
              "properties": {
                "os": { "type": "string" },
                "osVersion": { "type": "string" },
                "architecture": { "type": "string" },
                "powershellVersion": { "type": "string" },
                "worktreeVolume": { "type": "string" }
              }
            },
            "environmentFingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      ]
    }
  }
}
