{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/review-result.schema.json",
  "title": "CGC PMS AutoPilot Independent Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "issueId", "decision", "findings", "reviewedDiffHash", "reviewedAt"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "issueId": { "type": "string", "pattern": "^ISSUE-[0-9-]+$" },
    "decision": { "enum": ["pass", "needs_repair", "blocked"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line", "risk", "requiredEvidence"],
        "properties": {
          "severity": { "enum": ["blocking", "non_blocking"] },
          "file": { "type": "string" },
          "line": { "type": ["integer", "null"], "minimum": 1 },
          "risk": { "type": "string", "minLength": 1 },
          "requiredEvidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reviewedDiffHash": { "type": "string", "minLength": 1 },
    "reviewedAt": { "type": "string", "format": "date-time" }
  }
}
