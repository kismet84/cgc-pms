{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/task-score.schema.json",
  "title": "CGC PMS AutoPilot Task Score v1, v2, or disabled v2 candidate shadow",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "key", "issueId", "implementationCommit", "scoringVersion", "scoredAt", "total", "dimensions", "hardGatesPassed", "followupNetChange", "sourceRefs"],
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [1, 2] },
    "key": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "issueId": { "type": "string", "minLength": 1 },
    "implementationCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "scoringVersion": { "type": "string", "enum": ["autopilot-task-score/v1", "autopilot-task-score/v2", "autopilot-task-score/v2-candidate"] },
    "scoredAt": { "type": "string", "format": "date-time" },
    "total": { "type": "integer", "minimum": 0, "maximum": 100 },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deliveryCorrectness", "zeroDanglingIssues", "firstPassAcceptance", "stockIssueReduction"],
      "oneOf": [
        { "required": ["cycleEfficiency"] },
        { "required": ["taskExecutionEfficiency"] }
      ],
      "properties": {
        "deliveryCorrectness": { "$ref": "#/$defs/dimension35" },
        "zeroDanglingIssues": { "$ref": "#/$defs/dimension25" },
        "firstPassAcceptance": { "$ref": "#/$defs/dimension20" },
        "cycleEfficiency": { "$ref": "#/$defs/dimension10" },
        "taskExecutionEfficiency": { "$ref": "#/$defs/dimension10" },
        "stockIssueReduction": { "$ref": "#/$defs/dimension10" }
      }
    },
    "hardGatesPassed": { "const": true },
    "followupNetChange": { "type": "integer" },
    "executionTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wallClockSeconds", "businessPhaseSeconds", "controlPlaneSeconds", "semanticProgressAt", "livenessSignalsExcluded"],
      "properties": {
        "wallClockSeconds": { "type": "integer", "minimum": 0 },
        "businessPhaseSeconds": { "type": "integer", "minimum": 0 },
        "controlPlaneSeconds": { "type": "integer", "minimum": 0 },
        "semanticProgressAt": { "type": "string" },
        "livenessSignalsExcluded": { "const": true }
      }
    },
    "sourceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "shadow": { "type": "boolean" }
  },
  "$defs": {
    "dimension35": { "$ref": "#/$defs/dimension", "properties": { "max": { "const": 35 }, "score": { "type": "integer", "minimum": 0, "maximum": 35 } } },
    "dimension25": { "$ref": "#/$defs/dimension", "properties": { "max": { "const": 25 }, "score": { "type": "integer", "minimum": 0, "maximum": 25 } } },
    "dimension20": { "$ref": "#/$defs/dimension", "properties": { "max": { "const": 20 }, "score": { "type": "integer", "minimum": 0, "maximum": 20 } } },
    "dimension10": { "$ref": "#/$defs/dimension", "properties": { "max": { "const": 10 }, "score": { "type": "integer", "minimum": 0, "maximum": 10 } } },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "max", "evidence"],
      "properties": {
        "score": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 1 },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
