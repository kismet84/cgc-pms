{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/context-pack.schema.json",
  "title": "CGC PMS AutoPilot Context Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "issueId", "phase", "baseCommit", "executionBaseCommit", "candidateEvidenceHead", "controlPlanePolicyVersion", "controlPlanePolicyHash", "controlPlanePolicyRefs", "contextGeneratedAt", "readyContentHash",
    "diffHash", "goal", "nonGoals", "allowedPaths", "forbiddenPaths", "requiredCommands", "archiveReport",
    "relevantSymbols", "acceptedDecisions", "openRisks", "previousPhaseSummary"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "issueId": { "type": "string", "pattern": "^ISSUE-[0-9-]+$" },
    "phase": { "enum": ["implement", "repair", "review"] },
    "baseCommit": { "type": "string", "minLength": 7 },
    "executionBaseCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "candidateEvidenceHead": { "type": "string", "pattern": "^(?:[a-f0-9]{40})?$" },
    "controlPlanePolicyVersion": { "type": "string", "minLength": 1 },
    "controlPlanePolicyHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "controlPlanePolicyRefs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "contextGeneratedAt": { "type": "string", "format": "date-time" },
    "readyContentHash": { "type": "string", "minLength": 1 },
    "diffHash": { "type": "string", "minLength": 64, "maxLength": 64 },
    "goal": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "nonGoals": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "allowedPaths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "forbiddenPaths": { "type": "array", "items": { "type": "string" } },
    "requiredCommands": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "archiveReport": { "type": "string", "minLength": 1 },
    "relevantSymbols": { "type": "array", "maxItems": 12, "items": { "type": "string" } },
    "acceptedDecisions": { "type": "array", "items": { "type": "string" } },
    "openRisks": { "type": "array", "items": { "type": "string" } },
    "longRunningCommands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "expectedSeconds"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "expectedSeconds": { "type": "integer", "minimum": 601 }
        }
      }
    },
    "previousPhaseSummary": { "type": ["string", "null"], "maxLength": 5120 }
  }
}
