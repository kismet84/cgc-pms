{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cgc-pms.local/plugins/cgc-pms-autopilot/schemas/issue-checkpoint.schema.json",
  "title": "CGC PMS AutoPilot Issue Phase Checkpoint v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "issueId", "readyPath", "readyContentHash", "baseCommit", "worktree", "branch", "allowedPathsHash", "forbiddenPathsHash", "phase", "createdAt", "updatedAt", "phaseStartedAt", "lastHeartbeatAt", "artifacts", "evidence", "metrics", "quarantineReason", "runInstanceId", "leaseEpoch", "transitionId", "generation", "controlPlaneFingerprint", "semanticProgressAt", "failureRecoveryKeys"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "issueId": { "type": "string", "pattern": "^ISSUE-[0-9-]+$" },
    "readyPath": { "type": "string", "minLength": 1 },
    "readyContentHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "baseCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "worktree": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "allowedPathsHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "forbiddenPathsHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "phase": { "enum": ["IMPLEMENTING", "IMPLEMENTED", "VALIDATING", "VALIDATED", "REVIEWING", "REVIEW_TOOL_BLOCKED", "REVIEWED", "REPAIRING", "CLOSING", "IMPLEMENTATION_COMMITTED", "CLOSEOUT_COMMITTED", "REGISTERED", "CLOSED", "QUARANTINED"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "phaseStartedAt": { "type": "string", "format": "date-time" },
    "lastHeartbeatAt": { "type": "string", "format": "date-time" },
    "runInstanceId": { "type": "string" },
    "leaseEpoch": { "type": "string" },
    "transitionId": { "type": "string" },
    "generation": { "type": "integer", "minimum": 0 },
    "controlPlaneFingerprint": { "type": "string", "pattern": "^$|^[a-f0-9]{64}$" },
    "semanticProgressAt": { "type": ["string", "null"], "format": "date-time" },
    "failureRecoveryKeys": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "artifacts": { "type": "object" },
    "evidence": { "type": "object" },
    "metrics": { "type": "object" },
    "quarantineReason": { "type": ["string", "null"] }
  }
}
