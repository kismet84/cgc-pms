# Copy this file to .env and fill in real values before running docker compose up
# NEVER commit .env to git — this .env.example is the safe template
MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD}
MYSQL_DATABASE=cgc_pms
MYSQL_USER=cgc
MYSQL_PASSWORD=${MYSQL_PASSWORD}

REDIS_PASSWORD=${REDIS_PASSWORD}

# JWT signing secret — MUST be set for production (at least 256-bit, 32+ random chars)
# Generate with: openssl rand -base64 32
JWT_SECRET=${JWT_SECRET}

CORS_ALLOWED_ORIGINS=https://localhost

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}
