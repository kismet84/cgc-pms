# Copy to .env and replace ALL CHANGE-ME-* values with real secrets before running docker compose up
# NEVER commit .env to git — this .env.example is the safe template
# Real secrets must come from your local deploy/.env or an external secret injection mechanism.
MYSQL_ROOT_PASSWORD=CHANGE-ME-ROOT-PASSWORD
MYSQL_DATABASE=cgc_pms
MYSQL_USER=cgc
MYSQL_PASSWORD=CHANGE-ME-APP-PASSWORD

REDIS_PASSWORD=CHANGE-ME-REDIS-PASSWORD

# JWT signing secret — MUST be set for production (at least 256-bit, 32+ random chars)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE-ME-JWT-SECRET-AT-LEAST-32-CHARS

# Jasypt configuration encryption key — used to decrypt encrypted values in application-*.yml
# Generate with: openssl rand -base64 32
JASYPT_ENCRYPTOR_PASSWORD=CHANGE-ME-JASYPT-PASSWORD

# One-time platform bootstrap. Keep disabled except during first initialization.
# Password must be injected as a secret and removed/rotated immediately after first login.
CGCPMS_BOOTSTRAP_ENABLED=false
CGCPMS_BOOTSTRAP_TENANT_ID=0
CGCPMS_BOOTSTRAP_COMPANY_CODE=ROOT
CGCPMS_BOOTSTRAP_COMPANY_NAME=总公司
CGCPMS_BOOTSTRAP_DEPARTMENT_CODE=ROOT_DEPT
CGCPMS_BOOTSTRAP_DEPARTMENT_NAME=总部
CGCPMS_BOOTSTRAP_ADMIN_USERNAME=admin
CGCPMS_BOOTSTRAP_ADMIN_REAL_NAME=平台管理员
CGCPMS_BOOTSTRAP_ADMIN_EMAIL=
CGCPMS_BOOTSTRAP_ADMIN_PASSWORD=
CGCPMS_DEV_LOGIN_USERNAME=admin

CORS_ALLOWED_ORIGINS=https://localhost

# Container image tags (required for production, e.g. git SHA)
BACKEND_TAG=
FRONTEND_TAG=
# Docker registry URL (leave empty for local images, or e.g. "registry.example.com/")
REGISTRY_URL=

MINIO_ROOT_USER=CHANGE-ME-MINIO-USER
MINIO_ROOT_PASSWORD=CHANGE-ME-MINIO-PASSWORD
# Public HTTPS origin used in browser-consumed MinIO presigned URLs.
MINIO_PUBLIC_ENDPOINT=https://minio.example.com
MINIO_REGION=us-east-1

# Real malware scanner. Production must keep fail-close enabled.
VIRUS_SCAN_ENABLED=true
VIRUS_SCAN_HOST=clamav
VIRUS_SCAN_PORT=3310

# =============================================================================
# Backup configuration
# =============================================================================
# MySQL backup directory (host path)
BACKUP_DIR=./backups/mysql
# Number of daily full backups to retain (default: 7)
BACKUP_RETENTION_DAYS=7
