{
  "repoRoot": "D:\\projects-test\\cgc-pms",
  "baseBranch": "master",
  "worktreeRoot": "D:\\projects-test\\cgc-pms\\.worktrees",
  "autopilotDir": "D:\\projects-test\\cgc-pms\\.codex-autopilot",
  "mode": "codex-desktop-automation",
  "controlPlane": "scripts\\codex-autopilot\\autopilot-run-continuous.ps1",
  "continuousRunnerEntry": "scripts\\codex-autopilot\\autopilot-run-continuous.ps1",
  "autoMerge": true,
  "autoPush": false,
  "allowTestDataMutation": true,
  "allowTestDataDeletion": true,
  "requireTestDataResetMarker": true,
  "maxIssuesPerRun": 3,
  "maxParallel": 1,
  "maxParallelIssues": 1,
  "parallelSafetyMode": "strict-independent-only",
  "maxFilesChangedPerIssue": 20,
  "maxRunMinutes": 90,
  "cycleIntervalMinutes": 30,
  "issueExecutor": {
    "command": "codex",
    "args": [
      "exec",
      "--skip-git-repo-check",
      "--sandbox",
      "danger-full-access",
      "--ephemeral",
      "--json",
      "--cd",
      "{repoRoot}",
      "-"
    ],
    "stdinFile": "{promptFile}",
    "timeoutSeconds": 7200,
    "requireChangedFiles": true
  },
  "modelPolicy": {
    "mechanical": { "model": "gpt-5.6-luna", "thinking": "low" },
    "normal": { "model": "gpt-5.6-terra", "thinking": "medium" },
    "highRisk": { "model": "gpt-5.6-sol", "thinking": "high" },
    "formalReview": { "model": "gpt-5.6-sol", "thinking": "high" }
  },
  "issueReviewer": {
    "enabled": true,
    "model": "gpt-5.6-sol",
    "thinking": "high",
    "timeoutSeconds": 1200
  },
  "readyPlanner": {
    "enabled": true,
    "model": "gpt-5.6-sol",
    "thinking": "high",
    "timeoutSeconds": 1200
  },
  "closeout": {
    "enabled": true,
    "localCommit": true,
    "localFastForwardMerge": true
  },
  "allowedEpics": [
    "EPIC-000",
    "EPIC-001",
    "EPIC-002",
    "EPIC-003",
    "EPIC-004",
    "EPIC-005",
    "EPIC-006",
    "EPIC-007"
  ],
  "forbiddenPaths": [
    ".git\\**",
    "%USERPROFILE%\\**",
    "C:\\Windows\\**",
    "..\\**"
  ],
  "devDataResetAllowedWhen": {
    "springProfiles": [
      "dev",
      "test",
      "demo"
    ],
    "databaseHosts": [
      "localhost",
      "127.0.0.1"
    ],
    "requiredMarkerFile": ".codex-autopilot\\ALLOW_TEST_DATA_RESET",
    "dockerComposeProject": "cgc-pms"
  },
  "backendValidation": [
    "cd backend && mvn test"
  ],
  "frontendValidation": [
    "cd frontend-admin && pnpm type-check",
    "cd frontend-admin && pnpm build"
  ],
  "fullValidation": [
    "cd backend && mvn test",
    "cd frontend-admin && pnpm type-check",
    "cd frontend-admin && pnpm build"
  ],
  "mergeGateValidation": [
    "git diff --check"
  ]
}
