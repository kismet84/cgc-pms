{
  "name": "cgc-pms-frontend-admin-v2",
  "version": "0.1.0-dev.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "type-check:contracts": "tsc -p ../packages/frontend-contracts/tsconfig.json --noEmit",
    "lint:check": "eslint src tests e2e scripts eslint.config.js playwright.config.ts vite.config.ts vitest.config.ts --ext .vue,.js,.mjs,.ts,.jsx,.tsx",
    "test:unit": "vitest run tests/unit",
    "test:e2e:health": "playwright test e2e/health.spec.ts",
    "check:boundary": "node scripts/check-clean-room-boundary.mjs",
    "generate:route-ledger": "node scripts/generate-route-ledger.mjs --write",
    "check:route-ledger": "node scripts/generate-route-ledger.mjs --check",
    "check:bundle-size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@cgc-pms/frontend-contracts": "link:../packages/frontend-contracts",
    "axios": "^1.7.9",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.55.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.4",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "typescript": "~5.6.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.1.10"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
